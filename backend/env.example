# Database Configuration
# Option 1: Connection string (takes priority — required for Neon / hosted Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Option 2: Individual vars (used only when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hotels_db
DB_USER=your_username
DB_PASSWORD=your_password

# Server Configuration
PORT=5012
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_TOKEN_COOKIE_NAME=refreshToken
# Use none only when your frontend and backend are on different sites and HTTPS is enabled.
REFRESH_TOKEN_COOKIE_SAME_SITE=lax

#Image Kit Configuration
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# CORS Configuration
CORS_ORIGIN=http://localhost:5173


# Logging Configuration
LOG_LEVEL=debug
